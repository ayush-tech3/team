{
  "name": "@ledge-ai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --local --port 8787",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply ledge-ai-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ledge-ai-db --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "drizzle-orm": "^0.39.3",
    "hono": "^4.7.2",
    "jose": "^6.0.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "wrangler": "^3.109.2"
  }
}
